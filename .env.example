# Auguspay environment configuration. Copy to .env and fill in.
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///auguspay.db
# Optional: if set, /merchant/api/webhook/upi requires a valid
# X-Auguspay-Signature header (hex HMAC-SHA256 of the raw body with this key).
MERCHANT_WEBHOOK_SECRET=
# Uvicorn dev knobs
PORT=5000
RELOAD=1